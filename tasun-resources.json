{
  "meta": {
    "name": "Tasun resources",
    "ver": "v1-20260310_08",
    "notes": "Stable schema: pk=uid(uuid), required fields uid/rev/updatedAt/deleted; id is display only."
  },
  "api": {
    "base": "https://tasun-worker.wutasun.com",
    "health": "/api/tasun/health",
    "read": "/api/tasun/read",
    "merge": "/api/tasun/merge"
  },
  "resources": {
    "tasun-index-db": {
      "description": "Index config keys sync (AUTH/NAV/ROUTE)",
      "table": "tasun_index_db",
      "pk": "uid",
      "fields": {
        "uid": "TEXT",
        "id": "INTEGER",
        "k": "TEXT",
        "v": "TEXT",
        "rev": "INTEGER",
        "updatedAt": "INTEGER",
        "deleted": "INTEGER"
      }
    },
    "tasun-auth-table": {
      "description": "Auth table (users + nav buttons) shared across devices",
      "table": "tasun_auth_table",
      "pk": "uid",
      "fields": {
        "uid": "TEXT",
        "id": "INTEGER",
        "username": "TEXT",
        "role": "TEXT",
        "entry": "TEXT",
        "btn1": "INTEGER",
        "btn2": "INTEGER",
        "btn3": "INTEGER",
        "btn4": "INTEGER",
        "btn5": "INTEGER",
        "rev": "INTEGER",
        "updatedAt": "INTEGER",
        "deleted": "INTEGER"
      }
    }
  }
}