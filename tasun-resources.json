    "tasun-index-db": {
      "description": "Index config keys sync (AUTH/NAV/ROUTE)",
      "table": "tasun_index_db",
      "pk": "uid",
      "fields": {
        "uid": "TEXT",
        "id": "INTEGER",
        "k": "TEXT",
        "v": "TEXT",
        "rev": "INTEGER",
        "updatedAt": "INTEGER",
        "deleted": "INTEGER"
      }
    },
    "tasun-auth-table": {
      "description": "Auth table (users + nav buttons) shared across devices",
      "table": "tasun_auth_table",
